commit 65060c0bcaf5c5348ec04257f33bfc7f7f9f3f27
Author: suicune27 <whitehats27@gmail.com>
Date:   Sat Jun 6 00:51:58 2026 +0800

    feat(smoke-suite): stabilize runner, enforce env pre-scripts, and add rich execution logs
    
    - fix body recursion/memory pressure issues in smoke runs
    
    - enforce environment pre-request scripts before request dispatch
    
    - resolve script-mutated variables into headers/params/body before sending
    
    - add top-50 success/failed log capture and detailed request/response modal
    
    - compact smoke suite control center and chart/log visibility improvements

diff --git a/api/proxy.ts b/api/proxy.ts
index 43c6aef..24c7cc5 100644
--- a/api/proxy.ts
+++ b/api/proxy.ts
@@ -8,14 +8,27 @@ export default async function handler(req: VercelRequest, res: VercelResponse) {
 
   const { method, url, headers, data, params } = req.body;
 
+  const sanitizedHeaders: Record<string, string> = {};
+  if (headers && typeof headers === 'object') {
+    const blocklist = ['host', 'connection', 'content-length', 'origin', 'referer', 'accept-encoding', 'cookie'];
+    for (const [key, value] of Object.entries(headers)) {
+      if (!blocklist.includes(key.toLowerCase())) {
+        sanitizedHeaders[key] = String(value);
+      }
+    }
+  }
+
   try {
     const response = await axios({
       method,
       url,
-      headers,
+      headers: sanitizedHeaders,
       data,
       params,
       validateStatus: () => true, // Return status even if error
+      timeout: 25000, // Safe 25s timeout limit to prevent hanging connections
+      maxContentLength: 50 * 1024 * 1024, // Safe 50MB content length limit to shield against OOM leaks
+      maxBodyLength: 50 * 1024 * 1024,
     });
 
     res.status(200).json({
