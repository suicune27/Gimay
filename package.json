{
  "name": "gimay",
  "private": true,
  "version": "1.0.2",
  "description": "Gimay API Management Suite Client",
  "author": "Gimay Development Team",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rimraf dist dist_electron release",
    "lint": "tsc --noEmit",
    "lint:colors": "node scripts/lint-hex-colors.mjs",
    "icons": "node scripts/generate-icons.mjs",
    "desktop:dev": "concurrently -k \"npm run dev\" \"wait-on tcp:5173 && electron .\"",
    "desktop:build": "vite build && electron-builder",
    "desktop:win": "vite build && electron-builder --win",
    "desktop:portable": "vite build && electron-builder --win portable",
    "desktop:mac": "vite build && electron-builder --mac",
    "desktop:mac:x64": "vite build && electron-builder --mac --x64",
    "desktop:mac:arm64": "vite build && electron-builder --mac --arm64",
    "desktop:mac:universal": "vite build && electron-builder --mac universal",
    "desktop:linux": "vite build && electron-builder --linux",
    "desktop:pack": "vite build && electron-builder --dir"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@hello-pangea/dnd": "^18.0.1",
    "@monaco-editor/react": "^4.7.0",
    "@supabase/supabase-js": "^2.105.3",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.100.9",
    "@types/crypto-js": "^4.2.2",
    "@types/lodash": "^4.17.24",
    "@types/recharts": "^1.8.29",
    "@vercel/node": "^5.8.2",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.16.0",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "electron-is-dev": "^3.0.1",
    "express": "^4.21.2",
    "js-yaml": "^4.1.1",
    "lodash": "^4.18.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "prismjs": "^1.30.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "react-simple-code-editor": "^0.14.1",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.3",
    "wait-on": "^9.0.10",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.14.0",
    "@types/prismjs": "^1.26.6",
    "autoprefixer": "^10.4.21",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "rimraf": "^6.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  },
  "build": {
    "appId": "com.gimay.apiclient",
    "productName": "Gimay",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "dist_electron",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "asar": true,
    "compression": "maximum",
    "removePackageScripts": true,
    "publish": [
      {
        "provider": "github",
        "owner": "suicune27",
        "repo": "Gimay"
      }
    ],
    "win": {
      "icon": "gimay.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Gimay",
      "uninstallDisplayName": "Gimay API Client",
      "installerIcon": "gimay.ico",
      "uninstallerIcon": "gimay.ico",
      "installerHeaderIcon": "gimay.ico",
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "icon-512.png",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "dmg": {
      "sign": false
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "icon.png",
      "category": "Development"
    }
  },
  "allowScripts": {
    "sharp@0.34.5": true
  }
}
